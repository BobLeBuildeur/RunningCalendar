{
  "name": "running-calendar",
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "nx": "nx",
    "dev": "nx run site:dev",
    "build": "nx run site:build",
    "preview": "nx run site:preview",
    "astro": "astro --root apps/site",
    "validate-db": "node scripts/validate-db.mjs",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "start-server-and-test preview:e2e http://127.0.0.1:4321/RunningCalendar/ \"cypress run --spec cypress/e2e/date-range-picker.cy.ts\"",
    "test:e2e:demo": "start-server-and-test preview:e2e http://127.0.0.1:4321/RunningCalendar/ \"cypress run --spec cypress/e2e/date-range-picker-demo.cy.ts\"",
    "test:e2e:distance": "start-server-and-test preview:e2e http://127.0.0.1:4321/RunningCalendar/ \"cypress run --spec cypress/e2e/distance-range-filter.cy.ts,cypress/e2e/distance-badge-filter.cy.ts\"",
    "preview:e2e": "nx run site:preview-e2e"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/svelte": "^8.0.4",
    "@lucide/astro": "^1.8.0",
    "astro": "^6.1.5",
    "lucide": "^1.8.0",
    "pg": "^8.13.1",
    "posthog-js": "^1.369.3",
    "svelte": "^5.55.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "cypress": "^15.13.1",
    "nx": "^22.0.1",
    "start-server-and-test": "^3.0.2"
  }
}
