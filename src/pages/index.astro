---
import { races, raceUrl, formatKmList, type RaceRow } from '../data/races';

function distancesCell(r: RaceRow): string {
	if (r.distancesNote) return r.distancesNote;
	const s = formatKmList(r.distanceSlugs);
	return s ? `${s} km` : '—';
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>RunningCalendar</title>
	</head>
	<body>
		<h1>RunningCalendar</h1>
		<p>
			Initial race list from <a href="https://iguanasports.com.br">iguanasports.com.br</a> (calendar
			<a href="https://iguanasports.com.br/blogs/calendario-corridas-de-rua">calendário de corridas</a>).
		</p>

		<table border="1" cellpadding="8" cellspacing="0">
			<thead>
				<tr>
					<th scope="col">Date and time</th>
					<th scope="col">Location</th>
					<th scope="col">Name</th>
					<th scope="col">Distances (km)</th>
					<th scope="col">Link</th>
				</tr>
			</thead>
			<tbody>
				{
					races.map((r) => (
						<tr>
							<td>{r.dateTimeDisplay}</td>
							<td>
								{r.city}, {r.state}, {r.country}
							</td>
							<td>{r.name}</td>
							<td>{distancesCell(r)}</td>
							<td>
								<a href={raceUrl(r.calendarSlug)}>{raceUrl(r.calendarSlug)}</a>
							</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</body>
</html>
