---
import Calendar from '@lucide/astro/icons/calendar';
import MapPin from '@lucide/astro/icons/map-pin';
import RaceDateFilter from '../components/RaceDateFilter.svelte';
import RaceDistanceFilter from '../components/RaceDistanceFilter.svelte';
import RaceItem from '../components/RaceItem.svelte';
import { formatRaceLocationLine, loadCalendar } from '../data/races';
import '../styles/global.css';

const calendar = await loadCalendar();
const { races } = calendar;

const locationOptions = Array.from(new Set(races.map((r) => formatRaceLocationLine(r)))).sort((a, b) =>
	a.localeCompare(b, undefined, { sensitivity: 'base' }),
);

const distanceBounds = calendar.distanceBoundsFromRaces(races);

const filterBarInnerClass =
	`filter-bar__inner${distanceBounds ? '' : ' filter-bar__inner--two-cols'}`;
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap"
			rel="stylesheet"
		/>
		<title>RunningCalendar</title>
		<style>
			.race-list {
				display: flex;
				flex-direction: column;
				gap: var(--space-md);
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.filter-bar {
				background: var(--color-background);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-md);
				box-shadow: var(--shadow-sm);
				padding: var(--space-lg);
				margin: 0 0 var(--space-xl);
				overflow: visible;
			}

			.filter-bar__field {
				display: flex;
				flex-direction: column;
				gap: var(--space-sm);
				min-width: 0;
			}

			.filter-bar__label {
				display: inline-flex;
				align-items: center;
				gap: var(--space-xs);
				margin: 0;
				font-size: var(--text-meta);
				font-weight: var(--font-weight-semibold);
				color: var(--color-text-primary);
				line-height: 1.3;
			}

			.filter-bar__label-icon {
				flex-shrink: 0;
				color: var(--color-primary);
			}

			.filter-bar__select-wrap {
				position: relative;
			}

			.filter-bar__select-wrap::after {
				content: '';
				position: absolute;
				top: 50%;
				right: var(--space-md);
				width: 0.5rem;
				height: 0.5rem;
				border-right: 2px solid var(--color-text-secondary);
				border-bottom: 2px solid var(--color-text-secondary);
				transform: translateY(-65%) rotate(45deg);
				pointer-events: none;
			}

			.filter-bar__select {
				appearance: none;
				width: 100%;
				margin: 0;
				padding: var(--space-sm) calc(var(--space-lg) + var(--space-sm)) var(--space-sm) var(--space-md);
				font-size: var(--text-body);
				font-weight: var(--font-weight-regular);
				line-height: 1.4;
				color: var(--color-text-primary);
				background: var(--color-background);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-md);
				cursor: pointer;
			}

			.filter-bar__select:hover {
				border-color: var(--color-primary);
			}

			.filter-bar__select:focus {
				outline: none;
				border-color: var(--color-primary);
				box-shadow: 0 0 0 3px rgb(11 110 79 / 18%);
			}

			.filter-bar__select option {
				color: var(--color-text-primary);
			}

			.filter-bar__inner {
				display: grid;
				gap: var(--space-lg);
			}

			@media (min-width: 640px) {
				.filter-bar__inner {
					grid-template-columns: 1fr auto 1fr auto 1fr;
					align-items: start;
				}

				.filter-bar__inner--two-cols {
					grid-template-columns: 1fr auto 1fr;
				}
			}

			.filter-bar__divider {
				display: none;
				width: 1px;
				align-self: stretch;
				margin-block: var(--space-xs);
				background: var(--color-border);
			}

			@media (min-width: 640px) {
				.filter-bar__divider {
					display: block;
				}
			}

			/* Empty filter state — supporting text (design/5-language.md, color.text.secondary) */
			.race-list-empty {
				margin: 0;
				padding: var(--space-lg);
				font-size: var(--text-body);
				font-weight: var(--font-weight-regular);
				line-height: var(--line-height-body);
				color: var(--color-text-secondary);
				text-align: center;
			}
		</style>
	</head>
	<body class="layout">
		<div class="layout__container">
			<div class="grid">
				<header class="grid__col grid__col--span-12 page-header">
					<h1 class="page-header__title">
						<span class="page-header__title-icon-wrap" aria-hidden="true">
							<Calendar class="page-header__title-icon" size={36} />
						</span>
						RunningCalendar
					</h1>
				</header>

				<section class="filter-bar grid__col grid__col--span-12" aria-label="Filtrar corridas">
					<div class={filterBarInnerClass}>
						<div class="filter-bar__field">
							<label class="filter-bar__label" for="race-location-filter">
								<MapPin class="filter-bar__label-icon" size={16} aria-hidden={true} />
								Local
							</label>
							<div class="filter-bar__select-wrap">
								<select id="race-location-filter" class="filter-bar__select" autocomplete="off">
									<option value="">Qualquer local</option>
									{locationOptions.map((loc) => (
										<option value={loc}>{loc}</option>
									))}
								</select>
							</div>
						</div>

						{distanceBounds && (
							<>
								<div class="filter-bar__divider" aria-hidden="true" />
								<div class="filter-bar__field">
									<RaceDistanceFilter
										client:load
										minKm={distanceBounds.minKm}
										maxKm={distanceBounds.maxKm}
										sliderId="race-distance-filter"
									/>
								</div>
							</>
						)}

						<div class="filter-bar__divider" aria-hidden="true" />
						<div class="filter-bar__field">
							<RaceDateFilter client:load fieldId="race-date-filter" />
						</div>
					</div>
				</section>

				<ul class="race-list grid__col grid__col--span-12">
					{races.map((r) => <RaceItem race={r} calendar={calendar} />)}
				</ul>
				<p id="race-list-empty" class="race-list-empty grid__col grid__col--span-12" role="status" hidden>
					Nenhuma corrida corresponde aos filtros agora. Confira local, distância e datas — ampliar um deles
					costuma trazer de volta opções para comparar.
				</p>
			</div>
		</div>
		<script
			is:inline
			type="application/json"
			id="race-distance-bounds"
			set:html={JSON.stringify(distanceBounds)}
		/>
		<script is:inline>
			function parseDistanceKms(li) {
				const raw = li.getAttribute('data-distance-kms') ?? '';
				if (!raw) return [];
				return raw
					.split(';')
					.map((s) => Number(s.trim()))
					.filter((n) => Number.isFinite(n));
			}

			function readDistanceBounds() {
				const el = document.getElementById('race-distance-bounds');
				if (!el || !(el instanceof HTMLScriptElement)) return null;
				try {
					const t = el.textContent?.trim();
					if (!t || t === 'null') return null;
					const b = JSON.parse(t);
					if (
						typeof b?.minKm === 'number' &&
						typeof b?.maxKm === 'number' &&
						Number.isFinite(b.minKm) &&
						Number.isFinite(b.maxKm)
					) {
						return { minKm: b.minKm, maxKm: b.maxKm };
					}
				} catch {
					/* ignore */
				}
				return null;
			}

			const distanceBounds = readDistanceBounds();
			let distanceState = distanceBounds
				? {
						minKm: distanceBounds.minKm,
						maxKm: distanceBounds.maxKm,
						start: distanceBounds.minKm,
						end: distanceBounds.maxKm,
					}
				: null;

			/** @type {{ start: string, end: string } | null} */
			let dateRangeFilter = null;

			function applyRaceFilters() {
				const select = document.getElementById('race-location-filter');
				if (!select || !(select instanceof HTMLSelectElement)) return;
				const locationValue = select.value.trim();
				const items = document.querySelectorAll('.race-list .race-card');
				const emptyMsg = document.getElementById('race-list-empty');
				let visibleCount = 0;

				items.forEach((li) => {
					const loc = li.getAttribute('data-location') ?? '';
					const locationMatch = locationValue === '' || loc === locationValue;

					let distanceMatch = true;
					if (distanceState && distanceBounds) {
						const { minKm, maxKm, start, end } = distanceState;
						const noDistanceFilter = start <= minKm && end >= maxKm;
						if (!noDistanceFilter) {
							const kms = parseDistanceKms(li);
							distanceMatch =
								kms.length > 0 && kms.some((k) => k >= start && k <= end);
						}
					}

					let dateMatch = true;
					if (dateRangeFilter) {
						const raceDate = li.getAttribute('data-race-date') ?? '';
						dateMatch =
							raceDate !== '' &&
							raceDate >= dateRangeFilter.start &&
							raceDate <= dateRangeFilter.end;
					}

					const visible = locationMatch && distanceMatch && dateMatch;
					li.hidden = !visible;
					if (visible) visibleCount += 1;
				});

				if (emptyMsg) emptyMsg.hidden = visibleCount > 0;
			}

			document.addEventListener('runningcalendar:daterange', (e) => {
				const d = e?.detail;
				if (d && d.state === 'valid' && d.start && d.end) {
					dateRangeFilter = { start: d.start, end: d.end };
				} else {
					dateRangeFilter = null;
				}
				applyRaceFilters();
			});

			document.addEventListener('runningcalendar:distance', (e) => {
				const d = e?.detail;
				if (
					d &&
					typeof d.start === 'number' &&
					typeof d.end === 'number' &&
					typeof d.minKm === 'number' &&
					typeof d.maxKm === 'number'
				) {
					distanceState = {
						minKm: d.minKm,
						maxKm: d.maxKm,
						start: d.start,
						end: d.end,
					};
				}
				applyRaceFilters();
			});

			document.getElementById('race-location-filter')?.addEventListener('change', applyRaceFilters);

			applyRaceFilters();
		</script>
	</body>
</html>
