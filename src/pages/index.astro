---
import Calendar from '@lucide/astro/icons/calendar';
import MapPin from '@lucide/astro/icons/map-pin';
import RaceDateFilter from '../components/RaceDateFilter.svelte';
import RaceDistanceFilter from '../components/RaceDistanceFilter.svelte';
import RaceItem from '../components/RaceItem.svelte';
import PostHogInit from '../components/PostHogInit.svelte';
import RaceSavedFilter from '../components/RaceSavedFilter.svelte';
import { formatRaceLocationLine, loadCalendar } from '../data/races';
import { RACE_DISTANCE_SLIDER_MAX_KM, RACE_DISTANCE_SLIDER_MIN_KM } from '../lib/distanceFilter';
import { SAVED_RACES_STORAGE_KEY } from '../lib/savedRaces';
import '../styles/global.css';

const calendar = await loadCalendar();
const { races } = calendar;

const locationOptions = Array.from(new Set(races.map((r) => formatRaceLocationLine(r)))).sort((a, b) =>
	a.localeCompare(b, undefined, { sensitivity: 'base' }),
);

const distanceBounds = calendar.distanceBoundsFromRaces(races);
const hasListedDistances = races.some((r) => r.distanceSlugs.length > 0);

const filterBarInnerClass =
	`filter-bar__inner${hasListedDistances ? '' : ' filter-bar__inner--no-distance'}`;
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap"
			rel="stylesheet"
		/>
		<title>RunningCalendar</title>
		<style>
			.race-list {
				display: flex;
				flex-direction: column;
				gap: var(--space-md);
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.filter-bar {
				background: var(--color-background);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-md);
				box-shadow: var(--shadow-sm);
				padding: var(--space-lg);
				margin: 0 0 var(--space-xl);
				overflow: visible;
			}

			.filter-bar__field {
				display: flex;
				flex-direction: column;
				gap: var(--space-sm);
				min-width: 0;
			}

			.filter-bar__label {
				display: inline-flex;
				align-items: center;
				gap: var(--space-xs);
				margin: 0;
				font-size: var(--text-meta);
				font-weight: var(--font-weight-semibold);
				color: var(--color-text-primary);
				line-height: 1.3;
			}

			.filter-bar__label-icon {
				flex-shrink: 0;
				color: var(--color-primary);
			}

			.filter-bar__select-wrap {
				position: relative;
			}

			.filter-bar__select-wrap::after {
				content: '';
				position: absolute;
				top: 50%;
				right: var(--space-md);
				width: 0.5rem;
				height: 0.5rem;
				border-right: 2px solid var(--color-text-secondary);
				border-bottom: 2px solid var(--color-text-secondary);
				transform: translateY(-65%) rotate(45deg);
				pointer-events: none;
			}

			.filter-bar__select {
				appearance: none;
				width: 100%;
				margin: 0;
				padding: var(--space-sm) calc(var(--space-lg) + var(--space-sm)) var(--space-sm) var(--space-md);
				font-size: var(--text-body);
				font-weight: var(--font-weight-regular);
				line-height: 1.4;
				color: var(--color-text-primary);
				background: var(--color-background);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-md);
				cursor: pointer;
			}

			.filter-bar__select:hover {
				border-color: var(--color-primary);
			}

			.filter-bar__select:focus {
				outline: none;
				border-color: var(--color-primary);
				box-shadow: 0 0 0 3px rgb(11 110 79 / 18%);
			}

			.filter-bar__select option {
				color: var(--color-text-primary);
			}

			.filter-bar__inner {
				display: grid;
				gap: var(--space-lg);
			}

			@media (min-width: 640px) {
				.filter-bar__inner {
					grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
					align-items: start;
				}

				.filter-bar__inner--no-distance {
					grid-template-columns: 1fr auto 1fr auto 1fr;
				}
			}

			.filter-bar__divider {
				display: none;
				width: 1px;
				align-self: stretch;
				margin-block: var(--space-xs);
				background: var(--color-border);
			}

			@media (min-width: 640px) {
				.filter-bar__divider {
					display: block;
				}
			}

			/* Empty filter state — supporting text (design/5-language.md, color.text.secondary) */
			.race-list-empty {
				margin: 0;
				padding: var(--space-lg);
				font-size: var(--text-body);
				font-weight: var(--font-weight-regular);
				line-height: var(--line-height-body);
				color: var(--color-text-secondary);
				text-align: center;
			}
		</style>
	</head>
	<body class="layout" data-rc-source-page="/RunningCalendar/">
		<PostHogInit client:load />
		<div class="layout__container">
			<div class="grid">
				<header class="grid__col grid__col--span-12 page-header">
					<h1 class="page-header__title">
						<span class="page-header__title-icon-wrap" aria-hidden="true">
							<Calendar class="page-header__title-icon" size={36} />
						</span>
						RunningCalendar
					</h1>
				</header>

				<section class="filter-bar grid__col grid__col--span-12" aria-label="Filtrar corridas">
					<div class={filterBarInnerClass}>
						<div class="filter-bar__field">
							<label class="filter-bar__label" for="race-location-filter">
								<MapPin class="filter-bar__label-icon" size={16} aria-hidden={true} />
								Local
							</label>
							<div class="filter-bar__select-wrap">
								<select id="race-location-filter" class="filter-bar__select" autocomplete="off">
									<option value="">Qualquer local</option>
									{locationOptions.map((loc) => (
										<option value={loc}>{loc}</option>
									))}
								</select>
							</div>
						</div>

						{hasListedDistances && (
							<>
								<div class="filter-bar__divider" aria-hidden="true" />
								<div class="filter-bar__field">
									<RaceDistanceFilter
										client:load
										minKm={RACE_DISTANCE_SLIDER_MIN_KM}
										maxKm={RACE_DISTANCE_SLIDER_MAX_KM}
										step={0.001}
										sliderId="race-distance-filter"
									/>
								</div>
							</>
						)}

						<div class="filter-bar__divider" aria-hidden="true" />
						<div class="filter-bar__field">
							<RaceDateFilter client:load fieldId="race-date-filter" />
						</div>

						<div class="filter-bar__divider" aria-hidden="true" />
						<div class="filter-bar__field">
							<RaceSavedFilter client:load fieldId="race-saved-filter" />
						</div>
					</div>
				</section>

				<ul class="race-list grid__col grid__col--span-12">
					{races.map((r) => <RaceItem race={r} calendar={calendar} />)}
				</ul>
				<p id="race-list-empty" class="race-list-empty grid__col grid__col--span-12" role="status" hidden>
					Nenhuma corrida corresponde aos filtros agora. Confira local, distância e datas — ampliar um deles
					costuma trazer de volta opções para comparar.
				</p>
			</div>
		</div>
		<script
			is:inline
			type="application/json"
			id="race-distance-bounds"
			set:html={JSON.stringify(
				distanceBounds
					? {
							minKm: RACE_DISTANCE_SLIDER_MIN_KM,
							maxKm: RACE_DISTANCE_SLIDER_MAX_KM,
						}
					: null,
			)}
		/>
		<script
			is:inline
			type="application/json"
			id="running-calendar-config"
			set:html={JSON.stringify({ savedRacesKey: SAVED_RACES_STORAGE_KEY })}
		/>
		<script is:inline>
			function parseDistanceKms(li) {
				const raw = li.getAttribute('data-distance-kms') ?? '';
				if (!raw) return [];
				return raw
					.split(';')
					.map((s) => Number(s.trim()))
					.filter((n) => Number.isFinite(n));
			}

			function readDistanceBounds() {
				const el = document.getElementById('race-distance-bounds');
				if (!el || !(el instanceof HTMLScriptElement)) return null;
				try {
					const t = el.textContent?.trim();
					if (!t || t === 'null') return null;
					const b = JSON.parse(t);
					if (
						typeof b?.minKm === 'number' &&
						typeof b?.maxKm === 'number' &&
						Number.isFinite(b.minKm) &&
						Number.isFinite(b.maxKm)
					) {
						return { minKm: b.minKm, maxKm: b.maxKm };
					}
				} catch {
					/* ignore */
				}
				return null;
			}

			const distanceBounds = readDistanceBounds();
			let distanceState = distanceBounds
				? {
						minKm: distanceBounds.minKm,
						maxKm: distanceBounds.maxKm,
						start: distanceBounds.minKm,
						end: distanceBounds.maxKm,
					}
				: null;

			/** @type {{ start: string, end: string } | null} */
			let dateRangeFilter = null;

			let savedOnly = false;

			function readAppConfig() {
				const el = document.getElementById('running-calendar-config');
				if (!el || !(el instanceof HTMLScriptElement)) return { savedRacesKey: 'runningcalendar:saved-races' };
				try {
					const parsed = JSON.parse(el.textContent?.trim() || '{}');
					const key = typeof parsed?.savedRacesKey === 'string' && parsed.savedRacesKey.length > 0
						? parsed.savedRacesKey
						: 'runningcalendar:saved-races';
					return { savedRacesKey: key };
				} catch {
					return { savedRacesKey: 'runningcalendar:saved-races' };
				}
			}

			const SAVED_STORAGE_KEY = readAppConfig().savedRacesKey;

			/**
			 * Read the saved-race id set from localStorage. Re-reads each time the
			 * saved-only filter is (re-)applied so that toggling the saved state on
			 * individual cards does NOT change the UI until the user interacts with
			 * this filter (per the product spec).
			 */
			function readSavedIds() {
				try {
					const raw = window.localStorage.getItem(SAVED_STORAGE_KEY);
					if (!raw) return new Set();
					const parsed = JSON.parse(raw);
					if (!Array.isArray(parsed)) return new Set();
					return new Set(parsed.filter((x) => typeof x === 'string' && x.length > 0));
				} catch {
					return new Set();
				}
			}

			/** Snapshot of saved ids taken the last time the saved filter was toggled. */
			let savedIdsSnapshot = new Set();

			function applyRaceFilters() {
				const select = document.getElementById('race-location-filter');
				if (!select || !(select instanceof HTMLSelectElement)) return;
				const locationValue = select.value.trim();
				const items = document.querySelectorAll('.race-list .race-card');
				const emptyMsg = document.getElementById('race-list-empty');
				let visibleCount = 0;

				items.forEach((li) => {
					const loc = li.getAttribute('data-location') ?? '';
					const locationMatch = locationValue === '' || loc === locationValue;

					let distanceMatch = true;
					if (distanceState && distanceBounds) {
						const { minKm, maxKm, start, end } = distanceState;
						const noDistanceFilter = start <= minKm && end >= maxKm;
						if (!noDistanceFilter) {
							const kms = parseDistanceKms(li);
							const atMaxEnd = end >= maxKm - 1e-6;
							distanceMatch =
								kms.length > 0 &&
								kms.some((k) => {
									if (k < start) return false;
									if (atMaxEnd) return true;
									return k <= end;
								});
						}
					}

					let dateMatch = true;
					if (dateRangeFilter) {
						const raceDate = li.getAttribute('data-race-date') ?? '';
						dateMatch =
							raceDate !== '' &&
							raceDate >= dateRangeFilter.start &&
							raceDate <= dateRangeFilter.end;
					}

					let savedMatch = true;
					if (savedOnly) {
						const id = li.getAttribute('data-race-id') ?? '';
						savedMatch = id !== '' && savedIdsSnapshot.has(id);
					}

					const visible = locationMatch && distanceMatch && dateMatch && savedMatch;
					li.hidden = !visible;
					if (visible) visibleCount += 1;
				});

				if (emptyMsg) emptyMsg.hidden = visibleCount > 0;
			}

			document.addEventListener('runningcalendar:daterange', (e) => {
				const d = e?.detail;
				if (d && d.state === 'valid' && d.start && d.end) {
					dateRangeFilter = { start: d.start, end: d.end };
				} else {
					dateRangeFilter = null;
				}
				applyRaceFilters();
			});

			document.addEventListener('runningcalendar:distance', (e) => {
				const d = e?.detail;
				if (
					d &&
					typeof d.start === 'number' &&
					typeof d.end === 'number' &&
					typeof d.minKm === 'number' &&
					typeof d.maxKm === 'number'
				) {
					distanceState = {
						minKm: d.minKm,
						maxKm: d.maxKm,
						start: d.start,
						end: d.end,
					};
				}
				applyRaceFilters();
			});

			document.addEventListener('click', (event) => {
				const t = event.target;
				if (!(t instanceof Element)) return;
				const btn = t.closest('[data-testid="race-distance-badge"][data-distance-km]');
				if (!(btn instanceof HTMLButtonElement)) return;
				const raw = btn.getAttribute('data-distance-km');
				if (!raw) return;
				const km = Number(raw);
				if (!Number.isFinite(km)) return;
				event.preventDefault();
				document.dispatchEvent(
					new CustomEvent('runningcalendar:distance-from-badge', {
						detail: { km },
						bubbles: true,
					}),
				);
			});

			document.addEventListener('runningcalendar:savedfilter', (e) => {
				const d = e?.detail;
				savedOnly = Boolean(d && d.active);
				// Snapshot saved ids at the moment the user toggles the filter. Later
				// per-card toggles will NOT reapply the filter until the user
				// re-interacts with this control.
				savedIdsSnapshot = readSavedIds();
				applyRaceFilters();
			});

			function analyticsCapture(event, props) {
				if (typeof window.__rcCapture === 'function') window.__rcCapture(event, props);
			}

			function sourcePagePath() {
				const b = document.body;
				const raw = b?.dataset?.rcSourcePage;
				return typeof raw === 'string' && raw.length > 0 ? raw : '/RunningCalendar/';
			}

			document.getElementById('race-location-filter')?.addEventListener('change', (e) => {
				const sel = e.target;
				const locationValue =
					sel instanceof HTMLSelectElement ? sel.value.trim() : '';
				analyticsCapture('location_selected', {
					location_value: locationValue === '' ? 'all' : locationValue,
					source_page: sourcePagePath(),
				});
				applyRaceFilters();
			});

			// ----- Save-race heart button (delegated handler) -----
			function writeSavedIds(ids) {
				try {
					window.localStorage.setItem(SAVED_STORAGE_KEY, JSON.stringify(Array.from(ids)));
				} catch {
					/* ignore quota / private mode */
				}
			}

			function setButtonSaved(btn, saved) {
				btn.setAttribute('data-saved', saved ? 'true' : 'false');
				btn.setAttribute('aria-pressed', saved ? 'true' : 'false');
				const saveLbl = btn.getAttribute('data-label-save') ?? '';
				const unsaveLbl = btn.getAttribute('data-label-unsave') ?? '';
				btn.setAttribute('aria-label', saved ? unsaveLbl : saveLbl);
				btn.setAttribute('title', saved ? 'Corrida salva' : 'Salvar corrida');
				const icon = btn.querySelector('.save-race__icon');
				if (icon instanceof SVGElement) {
					icon.setAttribute('fill', saved ? 'currentColor' : 'none');
				}
			}

			function hydrateSaveButtons() {
				const ids = readSavedIds();
				const buttons = document.querySelectorAll('.save-race');
				buttons.forEach((btn) => {
					const id = btn.getAttribute('data-race-id') ?? '';
					setButtonSaved(btn, id !== '' && ids.has(id));
				});
			}

			document.addEventListener('click', (event) => {
				const target = event.target;
				if (!(target instanceof Element)) return;
				const btn = target.closest('.save-race');
				if (!(btn instanceof HTMLButtonElement)) return;
				event.preventDefault();
				event.stopPropagation();
				const id = btn.getAttribute('data-race-id') ?? '';
				if (!id) return;
				const ids = readSavedIds();
				const nextSaved = !ids.has(id);
				if (nextSaved) {
					ids.add(id);
				} else {
					ids.delete(id);
				}
				writeSavedIds(ids);
				const nameRaw = btn.getAttribute('data-race-name') ?? '';
				analyticsCapture('race_favorite_selected', {
					race_id: id,
					race_name: nameRaw.length > 0 ? nameRaw : id,
					is_saved: nextSaved,
					source_page: sourcePagePath(),
				});
				// Update the single button immediately; other occurrences of the same
				// id (should not happen but safe) are also refreshed below.
				document
					.querySelectorAll(`.save-race[data-race-id="${CSS.escape(id)}"]`)
					.forEach((b) => setButtonSaved(b, nextSaved));
				// Intentionally do NOT re-apply the saved-only filter here: per spec,
				// toggling the saved state of a race does not change the visible list
				// until the user re-interacts with the "Somente corridas salvas"
				// control.
			});

			hydrateSaveButtons();

			document.addEventListener('click', (event) => {
				const t = event.target;
				if (!(t instanceof Element)) return;
				const a = t.closest('a.race-card__action');
				if (!(a instanceof HTMLAnchorElement)) return;
				const card = a.closest('.race-card');
				const raceId = card?.getAttribute('data-race-id') ?? '';
				if (!raceId) return;
				analyticsCapture('race_detail_clicked', {
					race_id: raceId,
					destination_url: a.href,
					source_page: sourcePagePath(),
				});
			});

			applyRaceFilters();
		</script>
	</body>
</html>
